#!/bin/sh
# Pre-commit hook: block commits containing personal email
HOOK_FILE=".githooks/pre-commit"

PII_PATTERNS="1641797+AxDSan@users.noreply.github.com"

staged=$(git diff --cached --name-only | grep -v "^$HOOK_FILE$" || true)
if [ -n "$staged" ]; then
  if echo "$staged" | xargs grep -l "$PII_PATTERNS" 2>/dev/null; then
    echo "ERROR: PII detected in staged files. Remove before committing."
    echo "Found pattern: $PII_PATTERNS"
    exit 1
  fi
fi

# Also check git config
CURRENT_EMAIL=$(git config user.email)
if [ "$CURRENT_EMAIL" = "1641797+AxDSan@users.noreply.github.com" ]; then
  echo "INFO: Git user.email set to the noreply address (expected for Mnemosyne repo). Skipping check."
fi

exit 0
